# ========================================
# DeltaCast Environment Variables
# Copy to .env and fill in real values
# ========================================

# Server
SERVER_PORT=8080

# JWT Auth (HS256)
JWT_SECRET=your-jwt-secret-here

# Agora
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate
AGORA_REST_KEY=your-agora-rest-customer-id
AGORA_REST_SECRET=your-agora-rest-customer-secret
AGORA_NCS_SECRET=your-agora-ncs-secret

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_BUCKET_NAME=your-gcs-bucket-name
GCP_CDN_DOMAIN=your-cdn-domain.example.com

# YouTube (OAuth 2.0)
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REFRESH_TOKEN=your-youtube-refresh-token
