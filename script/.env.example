# ========================================
# DeltaCast script — 環境變數
# 複製為 .env 並填入真實值：
#   cp script/.env.example script/.env
# ========================================

# GCP — 必填（所有 GCP/YouTube 腳本皆需要）
GCP_PROJECT_ID=your-gcp-project-id

# GCS Bucket — 部分 GCP 腳本需要
GCP_BUCKET_NAME=your-gcs-bucket-name

# CDN Domain — GCP_CDN_DOMAIN 填入你的 CDN 子域名（Cloudflare A Record 指向 CDN IP 的那一條）
# ⚠️  Cloudflare 免費 SSL 只涵蓋兩層子域（*.your-domain），
#     三層（*.delta-cast.your-domain）需 Advanced Certificate Manager。
#     建議使用 cdn-delta-cast.your-domain（兩層，免費涵蓋）。
DNS_ZONE_DNS_NAME=your-cdn-domain.example.com.
DNS_ZONE_NAME=deltacast-cdn
DNS_RECORD_TTL=300
# 使用 Cloudflare 管理 DNS 時設為 true，跳過 GCP Cloud DNS Step
GCP_SKIP_CLOUD_DNS=true

# YouTube OAuth 2.0 — youtube-secure.sh / youtube-teardown.sh 需要
# youtube-setup.sh 會互動式引導取得這些值
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
