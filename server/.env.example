# ========================================
# DeltaCast Environment Variables
# Copy to .env and fill in real values
# ========================================

# Server
SERVER_PORT=8080
# 反向代理信任清單（逗號分隔的 IP / CIDR）
# 本機開發不需設定（不信任任何代理）；生產環境請依部署平台設定，例如：
#   Cloud Run:  TRUSTED_PROXIES=169.254.0.0/16
#   一般 LB:    TRUSTED_PROXIES=10.0.0.0/8
# TRUSTED_PROXIES=
# CORS 設定（全部為逗號分隔，預設值已適用本地開發）
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Origin,Content-Type,Authorization
CORS_EXPOSE_HEADERS=Content-Length
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE_HOURS=12

# JWT Auth (HS256)
JWT_SECRET=your-jwt-secret-here

# Agora
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate
AGORA_REST_KEY=your-agora-rest-customer-id
AGORA_REST_SECRET=your-agora-rest-customer-secret
# Agora Notifications — RTC Channel Event Callbacks secret (Console → Notifications → RTC Channel Event Callbacks)
AGORA_CHANNEL_NCS_SECRET=your-agora-channel-ncs-secret
# Agora Notifications — Media Push Restful API secret (Console → Notifications → Media Push Restful API)
AGORA_MEDIA_PUSH_NCS_SECRET=your-agora-media-push-ncs-secret
# Agora Media Push API region (必須與 CDN 來源位置一致)
# 可選值: cn (中國大陸), ap (亞洲，不含中國), na (北美), eu (歐洲)
AGORA_REGION=ap
# 是否啟用 Agora Media Push 轉碼（預設 false，直接轉送原始串流，費用較低）
# 設為 true 可啟用 H.264/AAC 720p 2500kbps 重新編碼後再推流
AGORA_TRANSCODING_ENABLED=false

# GCP
# 預設為 true, 設為 false 可停用 GCP 推流目標，停用時 GCP_* 等 env var 可以忽略
GCP_RELAY_ENABLED=true
# GCP 憑證（Application Default Credentials）
# 優先順序（高 → 低）：
# 1. GCP_SA_KEY_PATH — 直接指向 SA key 檔案，最簡單，優先使用。
#    - Cloud Run / GKE / GCE：使用 Workload Identity，不需設定。
#    - 本機 Docker：透過 docker-compose.local.yml volumes 掛入並在 environment 區塊設定，無需寫入此檔。
#    - AWS / Azure / 自建主機：需將 SA key 放至主機並設定此變數。
# 2. GCP_SA_KEY_JSON — fallback，用於無法掛載檔案的 PaaS（Railway / Render / Heroku）。
#    將 SA key 完整 JSON 內容貼入此變數，程式會直接讀取，不需要檔案。
# GCP_SA_KEY_PATH=/path/to/sa-key.json
# GCP_SA_KEY_JSON={"type":"service_account", ...}  # 貼入完整 JSON（單行）
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-east1
GCP_BUCKET_NAME=your-gcs-bucket-name
GCP_CDN_DOMAIN=your-cdn-domain.example.com

# YouTube (OAuth 2.0)
# 預設為true, 設為 false 可停用 YouTube 推流目標，停用時 YOUTUBE_* env var 可以忽略
YOUTUBE_RELAY_ENABLED=true
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REFRESH_TOKEN=your-youtube-refresh-token

