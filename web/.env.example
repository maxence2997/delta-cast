# ========================================
# DeltaCast Web Environment Variables
# Copy to .env.local and fill in real values
# ========================================

# DeltaCast backend API base URL (no trailing slash)
# 本機開發：http://localhost:8080
# 生產環境：https://<your-railway-domain>.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8080

# JWT Token 用於呼叫後端 API（server-side only，不會打包進 JS bundle）
# 本機開發：使用 server/ 的 JWT_SECRET 手動簽發
# 生產環境：設定在 CF Workers & Pages > Settings > Variables and Secrets
API_TOKEN=
